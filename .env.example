# OpenVort 环境变量配置

# LLM 配置
OPENVORT_LLM_PROVIDER=anthropic
OPENVORT_LLM_API_KEY=your-api-key-here
OPENVORT_LLM_API_BASE=https://api.anthropic.com
OPENVORT_LLM_MODEL=claude-sonnet-4-20250514

# 数据库 (Docker Compose 已内置 PostgreSQL，无需修改)
OPENVORT_DATABASE_URL=postgresql+asyncpg://openvort:openvort@postgres:5432/openvort

# 日志
OPENVORT_LOG_LEVEL=INFO

# 企业微信 Channel
OPENVORT_WECOM_CORP_ID=
OPENVORT_WECOM_APP_SECRET=
OPENVORT_WECOM_AGENT_ID=
OPENVORT_WECOM_CALLBACK_TOKEN=
OPENVORT_WECOM_CALLBACK_AES_KEY=

# 禅道插件
OPENVORT_ZENTAO_HOST=192.168.8.221
OPENVORT_ZENTAO_USER=zentao
OPENVORT_ZENTAO_PASSWORD=
OPENVORT_ZENTAO_DATABASE=zentao
